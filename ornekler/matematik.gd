// matematik.gd - Örnek GümüşDil modül dosyası
// Bu dosya "dahil_et" ile import edilebilir

fonksiyon topla(a, b) {
    dön a + b
}

fonksiyon carp(a, b) {
    dön a * b
}

fonksiyon kare(x) {
    dön x * x
}

fonksiyon mutlak(x) {
    eğer (x < 0) {
        dön -x
    }
    dön x
}

// Pi sabit degiskeni
değişken PI = 3.14159265358979
